{
  "name": "freight-bill-tracker-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --config wrangler.toml",
    "build": "wrangler deploy --dry-run --outdir dist --config wrangler.toml",
    "deploy": "wrangler deploy --config wrangler.toml",
    "db:create": "wrangler d1 create freight-bills-db --config wrangler.toml",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "wrangler d1 migrations apply freight-bills-db --config wrangler.toml",
    "db:migrate:local": "wrangler d1 migrations apply freight-bills-db --local --config wrangler.toml"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.0",
    "hono": "^4.12.12",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260409.1",
    "drizzle-kit": "^0.31.7",
    "typescript": "^6.0.0-dev.20260401",
    "wrangler": "^4.81.1"
  }
}
